---
import { getI18n } from '../../../i18n';
const lang = Astro.currentLocale || 'es';
const t = getI18n(lang);
const p = t.pages.paradigma.the_gap;
---
<section class="py-section bg-cnv-core text-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-flex items-center gap-2 text-xs font-700 tracking-[0.2em] uppercase text-cnv-generate mb-6 block">
        <span class="inline-block w-5 h-0.5 bg-cnv-generate mx-auto"></span>
        {p.tag}
      </span>
      <h2 class="text-headline font-800 animate-on-scroll">
        {p.title}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-white/10">
      {p.phases.map((item, i) => (
        <div class="p-8 bg-white/5 animate-on-scroll" style={`animation-delay: ${i * 0.1}s`}>
          <div class="text-xs font-700 tracking-widest uppercase mb-4 opacity-40">{item.phase}</div>
          <div class="w-8 h-1 mb-6" style={`background-color: ${item.color}`}></div>
          <h3 class="text-base font-700 mb-4">{item.title}</h3>
          <p class="text-sm text-white/50 leading-relaxed">{item.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>