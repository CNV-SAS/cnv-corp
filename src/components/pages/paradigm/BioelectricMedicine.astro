---
import { getI18n } from '../../../i18n';
const lang = Astro.currentLocale || 'es';
const t = getI18n(lang);
const p = t.pages.paradigma.bioelectric;
---
<section class="py-section">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <div class="section-tag mb-6">{p.tag}</div>
        <h2 class="text-headline font-800 text-cnv-core mb-6 animate-on-scroll">
          {p.title}
        </h2>
        <p class="text-base text-cnv-core/60 leading-relaxed mb-6 animate-on-scroll" set:html={p.p1}></p>
        <p class="text-base text-cnv-core/60 leading-relaxed mb-8 animate-on-scroll">
          {p.p2}
        </p>
        <div class="grid grid-cols-2 gap-4 animate-on-scroll">
          {p.params.map(param => (
            <div class="p-4 border border-cnv-core/10">
              <div class="text-lg font-900 text-cnv-core mb-1">{param.label}</div>
              <div class="text-xs text-cnv-core/40 font-500">{param.desc}</div>
            </div>
          ))}
        </div>
      </div>
      <div>
        <div class="aspect-square bg-cnv-core/5 border border-cnv-core/10 overflow-hidden">
          <img src="/images/bis-device.jpg" alt="Equipo BIS" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
          <div class="hidden w-full h-full items-center justify-center text-cnv-core/20 text-sm font-600 text-center p-8">
            <div>
              <div class="text-4xl mb-4">🔬</div>
              <div>bis-device.jpg</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>