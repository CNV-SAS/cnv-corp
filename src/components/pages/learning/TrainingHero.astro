---
import { getI18n } from '../../../i18n';
const lang = Astro.currentLocale || 'es';
const t = getI18n(lang);
const p = t.pages.formacion;
---
<section class="py-section border-b border-slate-100">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-3 h-3 rounded-full bg-cnv-transfer"></div>
        <span class="text-xs font-700 tracking-[0.2em] uppercase text-cnv-transfer">{p.tag}</span>
      </div>
      <h1 class="text-display font-900 text-cnv-core mb-8 text-balance animate-on-scroll">
        {p.title}
      </h1>
      <p class="text-subhead text-cnv-core/50 leading-relaxed max-w-2xl animate-on-scroll">
        {p.hero_body}
      </p>
    </div>
  </div>
</section>