---
import { getI18n } from '../../../i18n';
const lang = Astro.currentLocale || 'es';
const t = getI18n(lang);
const a = t.pages.formacion.academy_cta;
---
<section class="py-section bg-cnv-core text-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-headline font-800 mb-6 animate-on-scroll">
          {a.title}
        </h2>
        <p class="text-base text-white/70 leading-relaxed mb-10 animate-on-scroll">
          {a.body}
        </p>
        <div class="flex flex-wrap gap-4 animate-on-scroll">
          
          <button
            type="button"
            disabled
            class="inline-flex items-center gap-2 px-6 py-3 bg-white/90 text-cnv-core text-sm font-700 relative group cursor-not-allowed transition-colors"
          >
            <span>{a.primary_btn}</span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="opacity-60">
              <path d="M2 10L10 2M10 2H4M10 2v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            
            <span class="absolute -top-10 left-1/2 -translate-x-1/2 px-3 py-1.5 bg-gray-900 text-white text-[10px] font-800 uppercase tracking-widest rounded opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap pointer-events-none shadow-lg z-10">
              {t.footer.coming_soon}
            </span>
          </button>

          <a href={`${t.routes.contact}?perfil=professional`}
            class="inline-flex items-center gap-2 px-6 py-3 border-2 border-white/30 text-sm font-700 text-white hover:border-white transition-colors">
            {a.secondary_btn}
          </a>
        </div>
      </div>
      <div class="aspect-video bg-white/10 overflow-hidden">
        <img
          src="/images/learning-platform.webp"
          alt="Academia CNV Learning"
          class="w-full h-full object-cover"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <div class="hidden w-full h-full items-center justify-center text-white/30 text-sm font-600 text-center p-8">
          <div>
            <div class="text-4xl mb-4">🎓</div>
            <div>learning-platform</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>