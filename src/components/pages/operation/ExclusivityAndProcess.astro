---
import { getI18n } from '../../../i18n';
const lang = Astro.currentLocale || 'es';
const t = getI18n(lang);
---
<section class="py-section bg-cnv-core text-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <div>
        <span class="inline-flex items-center gap-2 text-xs font-700 tracking-[0.2em] uppercase text-cnv-generate mb-6 block">
          <span class="inline-block w-5 h-0.5 bg-cnv-generate"></span>
          {t.exclusivity.tag}
        </span>
        <h2 class="text-headline font-800 mb-6 animate-on-scroll">
          {t.exclusivity.title}
        </h2>
        <p class="text-sm text-white/50 leading-relaxed mb-8 animate-on-scroll">
          {t.exclusivity.subtitle}
        </p>
        <div class="flex flex-col gap-3 mb-10 animate-on-scroll">
          {t.exclusivity.requirements.map(req => (
            <div class="flex items-start gap-3 text-sm text-white/70">
              <svg class="flex-shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="7" stroke="#78be34" stroke-width="1.5"/>
                <path d="M4.5 8l2.5 2.5 4.5-5" stroke="#78be34" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {req}
            </div>
          ))}
        </div>
        <a href={`${t.routes.contact}?perfil=professional`} class="btn-primary">
          {t.final_cta.button}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
      <div>
        <span class="text-xs font-700 tracking-[0.2em] uppercase text-white/30 block mb-6">
          {t.process.tag}
        </span>
        <div class="flex flex-col">
          {t.process.steps.map((step, i) => (
            <div class="process-step animate-on-scroll" style={`animation-delay: ${i * 0.1}s`}>
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-8 h-8 rounded-full border border-white/20 flex items-center justify-center">
                  <span class="text-xs font-900 text-white/40">{i + 1}</span>
                </div>
                <div class="pt-1">
                  <h3 class="text-sm font-700 text-white mb-1">{step.title}</h3>
                  <p class="text-xs text-white/40 leading-relaxed">{step.body}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>