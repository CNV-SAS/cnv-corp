---
import { getI18n } from '../../../i18n';
const lang = Astro.currentLocale || 'es';
const t = getI18n(lang);
const d = t.pages.nosotros.direction;
---
<section class="py-section">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      <div class="lg:col-span-5">
        <div class="section-tag mb-6">{d.tag}</div>
        <h2 class="text-headline font-800 text-cnv-core mb-6 animate-on-scroll">
          {d.title}
        </h2>
        <p class="text-base text-cnv-core/60 leading-relaxed mb-6 animate-on-scroll" set:html={d.p1}></p>
        <p class="text-base text-cnv-core/60 leading-relaxed mb-10 animate-on-scroll">
          {d.p2}
        </p>
        <div class="flex flex-wrap gap-4 animate-on-scroll">
          <a href={t.routes.research} class="btn-primary">
            {d.btn_research}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href={t.external_links.obbia} target="_blank" rel="noopener" class="btn-secondary">
            {d.btn_obbia}
          </a>
        </div>
      </div>

      <div class="lg:col-span-6 lg:col-start-7">
        <div class="aspect-[4/3] bg-cnv-core/5 border border-cnv-core/10 overflow-hidden">
          <img
            src="/images/team.webp"
            alt="Equipo CNV"
            class="w-full h-full object-cover"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          />
          <div class="hidden w-full h-full items-center justify-center text-cnv-core/20 text-sm font-600 text-center p-8">
            <div>
              <div class="text-4xl mb-4">👥</div>
              <div>team</div>
              <div class="text-xs mt-2 opacity-50">Foto del equipo o dirección científica</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>