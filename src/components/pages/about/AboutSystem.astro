---
import { getI18n } from '../../../i18n';
const lang = Astro.currentLocale || 'es';
const t = getI18n(lang);
const sys = t.pages.nosotros.system;
---
<section class="py-section bg-cnv-core text-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="max-w-2xl mb-16">
      <span class="inline-flex items-center gap-2 text-xs font-700 tracking-[0.2em] uppercase text-cnv-generate mb-6 block">
        <span class="inline-block w-5 h-0.5 bg-cnv-generate"></span>
        {sys.tag}
      </span>
      <h2 class="text-headline font-800 animate-on-scroll">
        {sys.title}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-white/10">
      {sys.functions.map((item, i) => (
        <div class="p-10 bg-white/5 animate-on-scroll" style={`animation-delay: ${i * 0.1}s`}>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-3 h-3 rounded-full" style={`background-color: ${item.color}`}></div>
            <span class="text-xs font-700 tracking-[0.15em] uppercase" style={`color: ${item.color}`}>
              {item.role}
            </span>
          </div>
          <h3 class="text-lg font-800 text-white mb-4">{item.name}</h3>
          <p class="text-sm text-white/50 leading-relaxed">{item.body}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center animate-on-scroll">
      <p class="text-sm text-white/30 font-600 tracking-wider uppercase">
        {sys.flow_tag}
      </p>
      <div class="flex items-center justify-center gap-4 mt-4 flex-wrap">
        {sys.flow.map((item, i) => (
          <>
            <span class="text-sm text-white/60 font-600">
              {item}
            </span>
            {i < sys.flow.length - 1 && (
              <span class="text-sm text-white/20">→</span>
            )}
          </>
        ))}
      </div>
    </div>
  </div>
</section>