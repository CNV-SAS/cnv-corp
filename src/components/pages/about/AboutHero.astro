---
import { getI18n } from '../../../i18n';
const lang = Astro.currentLocale || 'es';
const t = getI18n(lang);
const p = t.pages.nosotros;
---
<section class="py-section border-b border-slate-100 grid-lines">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="max-w-4xl">
      <div class="section-tag mb-8">{p.tag}</div>
      <h1 class="text-display font-900 text-cnv-core text-balance mb-8 animate-on-scroll">
        {p.title}<br />
        <span class="text-cnv-generate">{p.title_highlight}</span>
      </h1>
      <p class="text-subhead text-cnv-core/60 leading-relaxed max-w-2xl animate-on-scroll">
        {p.hero_body}
      </p>
    </div>
  </div>
</section>