---
import { getI18n } from '../../../i18n';
const lang = Astro.currentLocale || 'es';
const t = getI18n(lang);
const o = t.pages.investigacion.obbia;
---
<section class="py-section bg-cnv-core text-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="inline-flex items-center gap-2 text-xs font-700 tracking-[0.2em] uppercase text-cnv-generate mb-6 block">
          <span class="inline-block w-5 h-0.5 bg-cnv-generate"></span>
          {o.tag}
        </span>
        <h2 class="text-headline font-800 mb-6 animate-on-scroll">
          {o.title}
        </h2>
        <p class="text-base text-white/60 leading-relaxed mb-6 animate-on-scroll">
          {o.p1}
        </p>
        <p class="text-base text-white/60 leading-relaxed mb-10 animate-on-scroll">
          {o.p2}
        </p>
        <button
          type="button"
          disabled
          class="inline-flex items-center gap-2 px-6 py-3 bg-cnv-generate text-white text-sm font-700 relative group cursor-not-allowed transition-colors"
        >
          <span>{o.btn_text}</span>
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="opacity-80">
            <path d="M2 10L10 2M10 2H4M10 2v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          
          <!-- El globo del Tooltip -->
          <span class="absolute -top-10 left-1/2 -translate-x-1/2 px-3 py-1.5 bg-gray-900 text-white text-[10px] font-800 uppercase tracking-widest rounded opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap pointer-events-none shadow-lg z-10">
            {t.footer.coming_soon}
          </span>
        </button>
      </div>

      <div class="grid grid-cols-2 gap-px bg-white/10">
        {o.stats.map((stat, i) => (
          <div class="p-8 bg-white/5 animate-on-scroll" style={`animation-delay: ${i * 0.1}s`}>
            <div class="text-2xl font-900 text-cnv-generate mb-3">{stat.val}</div>
            <div class="text-xs text-white/40 leading-relaxed uppercase tracking-wider">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>