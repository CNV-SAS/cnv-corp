---
import { getLangFromUrl, useTranslations } from '../../i18n';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-section bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">

      <div class="lg:col-span-5">
        <div class="sticky top-28">
          <div class="aspect-[3/4] bg-slate-50 border border-cnv-core/10 overflow-hidden relative group">
            <img
              src="/images/benefits-professional.jpg"
              alt="Profesional CNV"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div class="hidden w-full h-full items-center justify-center text-cnv-core/20 text-sm font-600 text-center p-8 absolute inset-0 bg-slate-50">
              <div>
                <div class="text-4xl mb-4">📷</div>
                <div>benefits-professional.jpg</div>
                <div class="text-xs mt-2 opacity-50">Reemplaza con tu imagen</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-6 lg:col-start-7 pt-8 lg:pt-0">
        <div class="section-tag mb-6 animate-on-scroll">{t.benefits.tag}</div>
        <h2 class="text-headline font-800 text-cnv-core mb-12 text-balance animate-on-scroll">
          {t.benefits.title}
        </h2>

        <div class="flex flex-col gap-0 border-t border-cnv-core/10">
          {t.benefits.items.map((item, i) => (
            <div class="py-8 border-b border-cnv-core/10 animate-on-scroll group" style={`animation-delay: ${i * 0.1}s`}>
              <div class="flex items-start gap-6">
                <div class="text-xl font-900 text-cnv-core/20 flex-shrink-0 w-8 text-right transition-colors duration-300 group-hover:text-cnv-core">
                  {String(i + 1).padStart(2, '0')}
                </div>
                <div>
                  <h3 class="text-base font-700 text-cnv-core mb-2">{item.title}</h3>
                  <p class="text-sm text-cnv-core/60 leading-relaxed">{item.body}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-12 animate-on-scroll">
          <a href="/contacto?perfil=professional" class="btn-primary">
            Postular al modelo
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>