---
import { getI18n } from '../../i18n';

const lang = Astro.currentLocale || 'es';
const t = getI18n(lang);
---

<section class="py-20 border-b border-slate-100">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-xs font-700 tracking-[0.2em] uppercase text-cnv-core/30">
        {t.partners.tag}
      </p>
    </div>
    <div class="flex flex-wrap items-center justify-center gap-12 opacity-40">
      {[1,2,3,4,5].map(i => (
        <div class="h-10 w-32 bg-cnv-core/10 flex items-center justify-center text-xs text-cnv-core/30 font-600">
          Partner {i}
        </div>
      ))}
    </div>
  </div>
</section>