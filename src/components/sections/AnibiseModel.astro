---
import { getI18n } from '../../i18n';

const lang = Astro.currentLocale || 'es';
const t = getI18n(lang);
---

<section id="modelo" class="py-section bg-slate-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="max-w-2xl mb-16">
      <div class="section-tag mb-6">{t.anibise.tag}</div>
      <h2 class="text-headline font-800 text-cnv-core mb-6 text-balance animate-on-scroll">
        {t.anibise.title}
      </h2>
      <p class="text-base text-cnv-core/80 animate-on-scroll">
        {t.anibise.subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-cnv-core/10 border border-cnv-core/10">
      {t.anibise.steps.map((step, i) => (
        <div class="bg-white p-8 animate-on-scroll" style={`animation-delay: ${i * 100}ms`}>
          <div class="text-4xl font-900 mb-6 text-cnv-core">{step.num}</div>
          <div class="w-8 h-0.5 bg-cnv-generate mb-4"></div>
          <h3 class="text-base font-700 text-cnv-core mb-3">{step.title}</h3>
          <p class="text-sm text-cnv-core/60 leading-relaxed">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>