---
import { getI18n, getRouteInOtherLang } from '../../i18n';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = getI18n(lang);

const otherLang = lang === 'es' ? 'EN' : 'ES';
const otherLangHref = getRouteInOtherLang(Astro.url);

// Consumimos las rutas limpiamente desde el diccionario.
// (Paradigma quedó integrado dentro de la página de CNV Care, por eso ya no va en el menú.)
const navLinks = [
  { href: t.routes.about, label: t.nav.nosotros },
  { href: t.routes.care, label: t.nav.operacion },
  { href: t.routes.learning, label: t.nav.formacion },
  { href: t.routes.research, label: t.nav.investigacion },
  { href: t.routes.noticias, label: t.nav.noticias },
  { href: t.routes.sitemap, label: t.footer.sitemap },
];

const currentPath = Astro.url.pathname;

// Una pestaña está "activa" si la ruta actual coincide con ella o con alguno de sus hijos.
const isActive = (link: { href: string; children?: { href: string }[] }) => {
  const paths = [link.href, ...(link.children?.map((c) => c.href) ?? [])];
  return paths.some((p) => currentPath === p || currentPath === p + '/');
};
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-transparent"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <nav class="flex items-center justify-between h-18 lg:h-20">

      <a href={t.routes.home} class="flex items-center gap-3 flex-shrink-0">
        <img
          src="/images/logo-horizontal-dark.svg"
          alt="Connected Nutrition Ventures"
          class="h-10 hidden dark-nav:block"
          id="logo-dark"
        />
        <img
          src="/images/logo-horizontal-light.svg"
          alt="Connected Nutrition Ventures"
          class="h-12 block"
          id="logo-light"
        />
      </a>

      <div class="hidden lg:flex items-center gap-8">
        {navLinks.map((link) => (
          link.children ? (
            <div class="relative group">
              <a
                href={link.href}
                class={`text-sm font-600 tracking-wide transition-colors duration-200 nav-link flex items-center gap-1.5 ${
                  isActive(link) ? 'text-cnv-execute' : 'text-cnv-core hover:text-cnv-execute'
                }`}
              >
                {link.label}
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class="transition-transform duration-200 group-hover:rotate-180">
                  <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              <div class="absolute top-full left-0 pt-3 hidden group-hover:block focus-within:block">
                <div class="bg-white rounded-xl shadow-xl border border-slate-100/80 py-2 min-w-[200px]">
                  {link.children.map((child) => (
                    <a
                      href={child.href}
                      class={`block px-5 py-2.5 text-sm font-600 tracking-wide transition-colors ${
                        currentPath === child.href || currentPath === child.href + '/'
                          ? 'text-cnv-execute'
                          : 'text-cnv-core hover:text-cnv-execute hover:bg-slate-50'
                      }`}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class={`text-sm font-600 tracking-wide transition-colors duration-200 nav-link ${
                currentPath === link.href || currentPath === link.href + '/'
                  ? 'text-cnv-execute'
                  : 'text-cnv-core hover:text-cnv-execute'
              }`}
            >
              {link.label}
            </a>
          )
        ))}
      </div>

      <div class="hidden lg:flex items-center gap-4">
        <a
          href={otherLangHref}
          class="text-xs font-700 tracking-widest text-cnv-core/50 hover:text-cnv-core transition-colors"
        >
          {otherLang}
        </a>
        <a
          href={t.routes.contact}
          class="text-sm font-600 tracking-wide text-cnv-core hover:text-cnv-execute transition-colors"
        >
          {t.nav.contacto}
        </a>
        <a
          href={t.routes.integrantes}
          class="btn-primary text-xs py-2.5 px-5"
        >
          {t.nav.integrantes}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <button
        id="menu-toggle"
        class="lg:hidden flex flex-col gap-1.5 p-2"
        aria-label="Toggle menu"
      >
        <span class="menu-line w-6 h-0.5 bg-cnv-core transition-all duration-300 block"></span>
        <span class="menu-line w-6 h-0.5 bg-cnv-core transition-all duration-300 block"></span>
        <span class="menu-line w-4 h-0.5 bg-cnv-core transition-all duration-300 block self-end"></span>
      </button>
    </nav>
  </div>

  <div
    id="mobile-menu"
    class="lg:hidden hidden absolute top-full left-0 right-0 bg-white border-t border-slate-100 shadow-xl"
  >
    <div class="max-w-7xl mx-auto px-6 py-8 flex flex-col gap-6">
      {navLinks.map((link) => (
        link.children ? (
          <div class="flex flex-col gap-4">
            <a
              href={link.href}
              class="text-base font-600 text-cnv-core hover:text-cnv-execute transition-colors"
            >
              {link.label}
            </a>
            <div class="flex flex-col gap-4 pl-4 border-l border-slate-100">
              {link.children.filter((child) => child.href !== link.href).map((child) => (
                <a
                  href={child.href}
                  class="text-sm font-600 text-cnv-core/80 hover:text-cnv-execute transition-colors"
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class="text-base font-600 text-cnv-core hover:text-cnv-execute transition-colors"
          >
            {link.label}
          </a>
        )
      ))}
      <div class="pt-4 border-t border-slate-100 flex flex-col gap-4">
        <a
          href={t.routes.integrantes}
          class="btn-primary text-sm justify-center"
        >
          {t.nav.integrantes}
        </a>
        <a
          href={t.routes.contact}
          class="text-sm font-600 text-center text-cnv-core hover:text-cnv-execute transition-colors"
        >
          {t.nav.contacto}
        </a>
        <a
          href={otherLangHref}
          class="text-xs font-700 tracking-widest text-center text-cnv-core/50"
        >
          {t.nav.switch_lang}
        </a>
      </div>
    </div>
  </div>
</header>

<div class="h-18 lg:h-20"></div>

<script>
  // En Astro, los scripts se ejecutan por componente, es mejor evitar null assertions (!) si la página cambia
  const navbar = document.getElementById('navbar');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  if (navbar && menuToggle && mobileMenu) {
    
    // 1. Extraemos la lógica a una función reutilizable
    const handleScroll = () => {
      if (window.scrollY > 50) {
        navbar.classList.add('bg-white/95', 'backdrop-blur-sm', 'shadow-sm', 'border-slate-100/80');
      } else {
        navbar.classList.remove('bg-white/95', 'backdrop-blur-sm', 'shadow-sm', 'border-slate-100/80');
      }
    };

    // 2. Ejecutamos la función inmediatamente al cargar la página (¡Esto arregla el bug!)
    handleScroll();

    // 3. Ejecutamos la función cada vez que el usuario haga scroll
    window.addEventListener('scroll', handleScroll);

    // Lógica del menú móvil
    menuToggle.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>