---
import { getLangFromUrl, useTranslations, getRouteInOtherLang } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const otherLang = lang === 'es' ? 'EN' : 'ES';
const otherLangHref = getRouteInOtherLang(Astro.url);

const navLinks = [
  { href: lang === 'es' ? '/paradigma' : '/en/paradigm', label: t.nav.paradigma },
  { href: lang === 'es' ? '/operacion' : '/en/operations', label: t.nav.operacion },
  { href: lang === 'es' ? '/formacion' : '/en/training', label: t.nav.formacion },
  { href: lang === 'es' ? '/investigacion' : '/en/research', label: t.nav.investigacion },
  { href: lang === 'es' ? '/nosotros' : '/en/about', label: t.nav.nosotros },
];

const currentPath = Astro.url.pathname;
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <nav class="flex items-center justify-between h-18 lg:h-20">

      <!-- Logo -->
      <a href={lang === 'es' ? '/' : '/en/'} class="flex items-center gap-3 flex-shrink-0">
        <img
          src="/images/logo-horizontal-dark.png"
          alt="Connected Nutrition Ventures"
          class="h-8 hidden dark-nav:block"
          id="logo-dark"
        />
        <img
          src="/images/logo-horizontal-light.png"
          alt="Connected Nutrition Ventures"
          class="h-8 block"
          id="logo-light"
        />
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`text-sm font-600 tracking-wide transition-colors duration-200 nav-link ${
              currentPath === link.href
                ? 'text-cnv-execute'
                : 'text-cnv-core hover:text-cnv-execute'
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Right side -->
      <div class="hidden lg:flex items-center gap-4">
        <a
          href={otherLangHref}
          class="text-xs font-700 tracking-widest text-cnv-core/50 hover:text-cnv-core transition-colors"
        >
          {otherLang}
        </a>
        <a
          href={lang === 'es' ? '/contacto' : '/en/contact'}
          class="btn-primary text-xs py-2.5 px-5"
        >
          {t.nav.cta}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="menu-toggle"
        class="lg:hidden flex flex-col gap-1.5 p-2"
        aria-label="Toggle menu"
      >
        <span class="menu-line w-6 h-0.5 bg-cnv-core transition-all duration-300 block"></span>
        <span class="menu-line w-6 h-0.5 bg-cnv-core transition-all duration-300 block"></span>
        <span class="menu-line w-4 h-0.5 bg-cnv-core transition-all duration-300 block self-end"></span>
      </button>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden absolute top-full left-0 right-0 bg-white border-t border-slate-100 shadow-xl"
  >
    <div class="max-w-7xl mx-auto px-6 py-8 flex flex-col gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-base font-600 text-cnv-core hover:text-cnv-execute transition-colors"
        >
          {link.label}
        </a>
      ))}
      <div class="pt-4 border-t border-slate-100 flex flex-col gap-4">
        <a
          href={lang === 'es' ? '/contacto' : '/en/contact'}
          class="btn-primary text-sm justify-center"
        >
          {t.nav.cta}
        </a>
        <a
          href={otherLangHref}
          class="text-xs font-700 tracking-widest text-center text-cnv-core/50"
        >
          {lang === 'es' ? 'View in English' : 'Ver en Español'}
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer -->
<div class="h-18 lg:h-20"></div>

<script>
  const navbar = document.getElementById('navbar')!;
  const menuToggle = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  // Scroll behavior
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;

    if (currentScroll > 50) {
      navbar.classList.add('bg-white/95', 'backdrop-blur-sm', 'shadow-sm', 'border-b', 'border-slate-100/80');
    } else {
      navbar.classList.remove('bg-white/95', 'backdrop-blur-sm', 'shadow-sm', 'border-b', 'border-slate-100/80');
    }
    lastScroll = currentScroll;
  });

  // Mobile menu
  menuToggle.addEventListener('click', () => {
    mobileMenu.classList.toggle('hidden');
  });
</script>