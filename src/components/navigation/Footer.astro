---
import { getI18n, getRouteInOtherLang } from '../../i18n';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = getI18n(lang);
const otherLangHref = getRouteInOtherLang(Astro.url);

const systemLinks = [
  { href: t.routes.paradigm, label: t.nav.paradigma },
  { href: t.routes.operations, label: 'CNV Care — ' + t.nav.operacion },
  { href: t.routes.training, label: 'CNV Learning — ' + t.nav.formacion },
  { href: t.routes.research, label: 'CNV Research — ' + t.nav.investigacion },
  { href: t.routes.about, label: t.nav.nosotros },
];
---

<footer class="bg-cnv-core text-white">
  <div class="h-1 w-full flex">
    <div class="flex-1 bg-cnv-execute"></div>
    <div class="flex-1 bg-cnv-transfer"></div>
    <div class="flex-1 bg-cnv-generate"></div>
    <div class="flex-1 bg-cnv-bio"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">

      <div class="md:col-span-4">
        <img
          src="/images/logo-horizontal-dark.png"
          alt="Connected Nutrition Ventures"
          class="h-8 mb-6"
        />
        <p class="text-sm text-white/60 leading-relaxed max-w-xs">
          {t.footer.tagline}
        </p>
        <div class="mt-8">
          <p class="text-xs font-700 tracking-[0.2em] uppercase text-white/30 mb-3">
            {t.footer.ecosystem_title}
          </p>
          <div class="flex flex-col gap-2">
            <a href={t.external_links.atlas} target="_blank" rel="noopener"
              class="text-xs text-white/50 hover:text-cnv-bio transition-colors flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-cnv-execute flex-shrink-0"></span>
              {t.footer.subdomain_atlas}
            </a>
            <a href={t.external_links.academy} target="_blank" rel="noopener"
              class="text-xs text-white/50 hover:text-cnv-bio transition-colors flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-cnv-transfer flex-shrink-0"></span>
              {t.footer.subdomain_academy}
            </a>
            <a href={t.external_links.obbia} target="_blank" rel="noopener"
              class="text-xs text-white/50 hover:text-cnv-bio transition-colors flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-cnv-generate flex-shrink-0"></span>
              {t.footer.subdomain_obbia}
            </a>
          </div>
        </div>
      </div>

      <div class="md:col-span-3 md:col-start-6">
        <p class="text-xs font-700 tracking-[0.2em] uppercase text-white/30 mb-6">
          {t.footer.links_system}
        </p>
        <div class="flex flex-col gap-3">
          {systemLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm text-white/60 hover:text-white transition-colors"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <div class="md:col-span-3 md:col-start-10">
        <p class="text-xs font-700 tracking-[0.2em] uppercase text-white/30 mb-6">
          {t.footer.access_title}
        </p>
        <a
          href={t.routes.contact}
          class="inline-flex items-center gap-2 px-6 py-3 border-2 border-white/20 text-sm font-600 text-white hover:border-cnv-generate hover:text-cnv-generate transition-all duration-300"
        >
          {t.nav.cta}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <div class="mt-8">
          <a href={otherLangHref}
            class="text-xs font-700 tracking-widest text-white/30 hover:text-white/60 transition-colors">
            {t.nav.switch_lang}
          </a>
        </div>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <p class="text-xs text-white/30">
        {t.footer.copyright}
      </p>
      <div class="flex gap-6">
        <a href={t.routes.privacy} class="text-xs text-white/30 hover:text-white/60 transition-colors">
          {t.footer.privacy}
        </a>
        <a href={t.routes.terms} class="text-xs text-white/30 hover:text-white/60 transition-colors">
          {t.footer.terms}
        </a>
      </div>
    </div>
  </div>
</footer>