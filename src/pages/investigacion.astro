---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getI18n } from '../i18n';

const lang = Astro.currentLocale || 'es';
const t = getI18n(lang);
const p = t.pages.investigacion;
---

<BaseLayout
  title={`${p.title} — Connected Nutrition Ventures`}
  description="CNV Research diseña, valida y hace evolucionar el modelo ANI BIS-E con datos reales de población latinoamericana, a través del observatorio OB BIA LATAM."
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@500;600&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="cnvresearch-root">

    <!-- HERO -->
    <header class="hero">
      <div class="wrap">
        <div class="kicker">CNV Research</div>
        <h1>La autoridad científica del ecosistema.</h1>
        <p>CNV Research asegura que todo el ecosistema opere bajo evidencia sólida, coherente y actualizada. Diseña, valida y hace evolucionar el modelo ANI BIS-E con datos reales de población latinoamericana.</p>
      </div>
      <div class="hero-deco" aria-hidden="true">R</div>
    </header>

    <!-- FUNCIONES -->
    <section id="funciones">
      <div class="wrap">
        <div class="kicker">Qué hacemos</div>
        <h2>Cinco funciones que sostienen el modelo.</h2>
        <div class="func-grid" id="funcGrid"></div>
      </div>
    </section>

    <!-- PRODUCCIÓN CIENTÍFICA: tabs -->
    <section class="ciencia" id="produccion">
      <div class="wrap">
        <div class="kicker">Producción científica</div>
        <h2>Del dato al conocimiento publicado.</h2>
        <p class="lead">Libros académicos, artículos científicos y tesis doctoral. Producción personal del Director Científico, respaldo de la solidez del ecosistema.</p>
        <div class="tabs">
          <button class="tab-btn on" data-tab="libros">Libros académicos</button>
          <button class="tab-btn" data-tab="articulos">Artículos y tesis</button>
        </div>
        <div class="tab-panel on" id="tab-libros">
          <div class="books-grid" id="booksGrid"></div>
        </div>
        <div class="tab-panel" id="tab-articulos">
          <div class="art-list" id="artList"></div>
        </div>
      </div>
    </section>

    <!-- OB BIA LATAM -->
    <section class="obbia" id="obbia">
      <div class="wrap">
        <div class="kicker">Plataforma de análisis y producción de conocimiento</div>
        <h2>Observatorio Latinoamericano de Bioimpedancia</h2>
        <p class="lead">OB BIA LATAM es la capa operativa de CNV Research. Concentra la data clínica del ecosistema, la valida científicamente y produce el conocimiento que mantiene al modelo en la frontera de la evidencia.</p>
        <div class="stats" id="statsGrid"></div>
        <div class="obbia-desc">
          <p>Las publicaciones, bases de datos, reportes técnicos y divulgación científica del observatorio viven en su propio subdominio. La dirección científica del ecosistema opera a través de OB BIA LATAM como plataforma de análisis, validación y producción de conocimiento.</p>
          <a href="/ob-bia-latam.html" target="_blank" rel="noopener" class="btn-outline-white">Ir al Observatorio OB BIA LATAM &rarr;</a>
        </div>
      </div>
    </section>

    <!-- NEWSLETTER: artículos destacados de LinkedIn -->
    <section class="nl" id="newsletter">
      <div class="wrap">
        <div class="kicker">Desde la dirección científica</div>
        <h2>Bioimpedancia: el arte de medir lo invisible.</h2>
        <p class="lead">Newsletter de LinkedIn del Dr. Gildardo de Jesús Uribe Gil. Artículos seleccionados del observatorio.</p>
        <div class="nl-grid" id="nlGrid"></div>
      </div>
    </section>

    <p class="cr-copy">Indicadores ANI BIS-E &copy; Gildardo de Jesús Uribe Gil, 2026</p>

    <!-- LIGHTBOX (modelo de imagenes igual que Nosotros) -->
    <div class="cr-lb" id="crLb" role="dialog" aria-modal="true">
      <button class="cr-cls" id="crLbClose" aria-label="Cerrar">&times;</button>
      <img id="crLbImg" src="" alt="" />
      <div class="cr-cap" id="crLbCap"></div>
    </div>

  </div>

  <style is:global>
    /* Estilos confinados a .cnvresearch-root para NO afectar la barra ni el footer globales.
       is:global porque las tarjetas se generan por JS en runtime. */
    .cnvresearch-root{
      --navy:#16324F;--teal:#147F76;--gold:#C9A02C;--green:#5E9B3F;--burgundy:#7C2E50;
      --accent:#C9A961;--ink:#1A2B3C;--muted:#5B6B7A;
      --bg:#FFFFFF;--soft:#F6F4EF;--line:#E4DECF;
      --display:'Spectral',Georgia,serif;
      --body:'Inter',system-ui,sans-serif;
      --mono:'IBM Plex Mono',monospace;
      font-family:var(--body);color:var(--ink);background:var(--bg);line-height:1.6;-webkit-font-smoothing:antialiased;
    }
    .cnvresearch-root a{color:inherit;text-decoration:none}
    .cnvresearch-root img{max-width:100%;display:block}
    .cnvresearch-root .wrap{max-width:1120px;margin:0 auto;padding:0 24px}
    .cnvresearch-root section{padding:96px 0}
    .cnvresearch-root h2{font-family:var(--display);font-weight:700;font-size:clamp(26px,4vw,42px);color:var(--navy);line-height:1.12;margin:14px 0 0}
    .cnvresearch-root .lead{font-size:18px;color:var(--muted);max-width:640px;margin-top:16px}
    .cnvresearch-root .kicker{font-family:var(--mono);font-size:12px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--accent)}
    .cnvresearch-root .kicker::before{content:"";display:inline-block;width:26px;height:1px;background:var(--accent);vertical-align:middle;margin-right:10px;transform:translateY(-3px)}

    /* HERO */
    .cnvresearch-root .hero{background:var(--navy);color:#fff;padding:96px 0 84px;position:relative;overflow:hidden}
    .cnvresearch-root .hero .kicker{color:var(--accent)}
    .cnvresearch-root .hero h1{font-family:var(--display);font-weight:700;font-size:clamp(32px,5.5vw,60px);line-height:1.06;margin:18px 0 0;max-width:16ch;color:#fff}
    .cnvresearch-root .hero p{font-size:clamp(16px,2vw,20px);color:#cfdae6;max-width:620px;margin-top:24px}
    .cnvresearch-root .hero-deco{position:absolute;right:-60px;top:50%;transform:translateY(-50%);opacity:.07;font-family:var(--mono);font-size:220px;font-weight:600;color:#fff;pointer-events:none;user-select:none}

    /* FUNCIONES */
    .cnvresearch-root .func-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:48px}
    @media(max-width:900px){.cnvresearch-root .func-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:560px){.cnvresearch-root .func-grid{grid-template-columns:1fr}}
    .cnvresearch-root .func-card{background:var(--soft);border:1px solid var(--line);border-radius:14px;padding:28px;transition:transform .2s,box-shadow .2s}
    .cnvresearch-root .func-card:hover{transform:translateY(-3px);box-shadow:0 10px 28px rgba(22,50,79,.08)}
    .cnvresearch-root .func-icon{width:44px;height:44px;border-radius:10px;display:grid;place-items:center;margin-bottom:16px;font-size:22px}
    .cnvresearch-root .func-card h3{font-family:var(--display);font-size:19px;color:var(--navy);margin-bottom:10px}
    .cnvresearch-root .func-card p{font-size:15px;color:var(--muted)}

    /* PRODUCCIÓN CIENTÍFICA */
    .cnvresearch-root .ciencia{background:var(--soft)}
    .cnvresearch-root .tabs{display:flex;gap:0;margin-top:36px;border-bottom:2px solid var(--line);overflow-x:auto}
    .cnvresearch-root .tab-btn{font-family:var(--mono);font-size:12px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--muted);background:none;border:none;padding:14px 22px;cursor:pointer;border-bottom:3px solid transparent;margin-bottom:-2px;transition:color .2s;white-space:nowrap}
    .cnvresearch-root .tab-btn:hover{color:var(--navy)}
    .cnvresearch-root .tab-btn.on{color:var(--teal);border-bottom-color:var(--teal)}
    .cnvresearch-root .tab-panel{display:none;padding-top:40px}
    .cnvresearch-root .tab-panel.on{display:block}

    /* LIBROS */
    .cnvresearch-root .books-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}
    @media(max-width:820px){.cnvresearch-root .books-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:480px){.cnvresearch-root .books-grid{grid-template-columns:1fr}}
    .cnvresearch-root .book-card{background:#fff;border:1px solid var(--line);border-radius:14px;overflow:hidden;transition:transform .25s,box-shadow .25s}
    .cnvresearch-root .book-card:hover{transform:translateY(-4px);box-shadow:0 16px 36px rgba(22,50,79,.1)}
    .cnvresearch-root .book-cover-wrap{position:relative;aspect-ratio:2/3;overflow:hidden;background:#eef1f4;cursor:zoom-in}
    .cnvresearch-root .book-ph{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:center;align-items:center;gap:10px;padding:22px;text-align:center;background:linear-gradient(160deg,var(--navy),#0e2237)}
    .cnvresearch-root .book-ph-tag{font-family:var(--mono);font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--accent);font-weight:600}
    .cnvresearch-root .book-ph-t{font-family:var(--display);font-size:15px;color:#fff;line-height:1.25}
    .cnvresearch-root .book-cover{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
    .cnvresearch-root .book-body{padding:20px}
    .cnvresearch-root .book-tag{font-family:var(--mono);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--teal);font-weight:600}
    .cnvresearch-root .book-title{font-family:var(--display);font-size:17px;color:var(--navy);margin:6px 0 8px;line-height:1.2}
    .cnvresearch-root .book-desc{font-size:13.5px;color:var(--muted);margin-bottom:16px;line-height:1.5}
    .cnvresearch-root .book-author{font-size:12px;color:var(--muted);margin-bottom:16px;font-style:italic}
    .cnvresearch-root .book-btns{display:flex;gap:8px;flex-wrap:wrap}
    .cnvresearch-root .btn-sm{font-size:12.5px;font-weight:600;padding:8px 14px;border-radius:7px;border:1.5px solid var(--navy);color:var(--navy);transition:all .2s;cursor:pointer;background:none}
    .cnvresearch-root .btn-sm:hover{background:var(--navy);color:#fff}
    .cnvresearch-root .btn-sm.filled{background:var(--teal);border-color:var(--teal);color:#fff}
    .cnvresearch-root .btn-sm.filled:hover{background:#0f6b63}

    /* ARTÍCULOS Y TESIS */
    .cnvresearch-root .art-list{display:flex;flex-direction:column;gap:18px}
    .cnvresearch-root .art-card{background:#fff;border:1px solid var(--line);border-radius:12px;padding:24px 28px;display:grid;grid-template-columns:1fr auto;gap:16px;align-items:start;transition:box-shadow .2s}
    .cnvresearch-root .art-card:hover{box-shadow:0 8px 24px rgba(22,50,79,.07)}
    .cnvresearch-root .art-tag{font-family:var(--mono);font-size:11px;letter-spacing:2px;text-transform:uppercase;font-weight:600;margin-bottom:6px}
    .cnvresearch-root .art-title{font-family:var(--display);font-size:18px;color:var(--navy);line-height:1.2;margin-bottom:8px}
    .cnvresearch-root .art-meta{font-size:13.5px;color:var(--muted)}
    .cnvresearch-root .art-meta strong{color:var(--ink)}
    .cnvresearch-root .art-status{font-family:var(--mono);font-size:11px;font-weight:600;padding:5px 12px;border-radius:20px;white-space:nowrap;align-self:start}
    .cnvresearch-root .status-pub{background:#e6f4f1;color:var(--teal)}
    .cnvresearch-root .status-wip{background:#fdf6e3;color:#8a6800}
    .cnvresearch-root .status-thesis{background:#eef0f8;color:var(--navy)}

    /* OB BIA LATAM */
    .cnvresearch-root .obbia{background:var(--navy);color:#fff}
    .cnvresearch-root .obbia h2{color:#fff}
    .cnvresearch-root .obbia .lead{color:#bcccdb}
    .cnvresearch-root .obbia p{color:#cfdae6;font-size:16.5px;max-width:700px;margin-top:20px}
    .cnvresearch-root .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-top:48px}
    @media(max-width:760px){.cnvresearch-root .stats{grid-template-columns:repeat(2,1fr)}}
    .cnvresearch-root .stat{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);border-radius:12px;padding:28px 20px;text-align:center}
    .cnvresearch-root .stat .val{font-family:var(--mono);font-size:36px;font-weight:600;color:var(--accent);line-height:1}
    .cnvresearch-root .stat .lbl{font-size:13px;color:#9fb8cc;margin-top:8px;line-height:1.3}
    .cnvresearch-root .obbia-desc{margin-top:36px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:14px;padding:32px}
    .cnvresearch-root .obbia-desc p{margin-top:0}
    .cnvresearch-root .btn-outline-white{display:inline-block;margin-top:24px;border:1.5px solid rgba(255,255,255,.4);color:#fff;font-size:14px;font-weight:600;padding:12px 22px;border-radius:8px;transition:all .2s}
    .cnvresearch-root .btn-outline-white:hover{background:#fff;color:var(--navy)}

    /* NEWSLETTER */
    .cnvresearch-root .nl{border-top:1px solid var(--line)}
    .cnvresearch-root .nl-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:40px}
    @media(max-width:820px){.cnvresearch-root .nl-grid{grid-template-columns:1fr}}
    .cnvresearch-root .nl-card{background:var(--soft);border:1px solid var(--line);border-radius:12px;padding:22px;transition:transform .2s}
    .cnvresearch-root .nl-card:hover{transform:translateY(-2px)}
    .cnvresearch-root .nl-card .ed{font-family:var(--mono);font-size:11px;letter-spacing:2px;color:var(--accent);font-weight:600;text-transform:uppercase}
    .cnvresearch-root .nl-card h4{font-family:var(--display);font-size:17px;color:var(--navy);margin:6px 0 10px;line-height:1.2}
    .cnvresearch-root .nl-card p{font-size:13.5px;color:var(--muted)}
    .cnvresearch-root .nl-card a.leer{display:inline-block;margin-top:14px;font-size:13px;font-weight:600;color:var(--teal)}
    .cnvresearch-root .nl-card a.leer:hover{text-decoration:underline}

    .cnvresearch-root .cr-copy{text-align:center;font-family:var(--mono);font-size:12px;letter-spacing:.5px;color:var(--muted);padding:36px 24px 10px}

    /* LIGHTBOX */
    .cnvresearch-root .cr-lb{position:fixed;inset:0;background:rgba(10,20,30,.92);display:none;align-items:center;justify-content:center;z-index:300;padding:32px}
    .cnvresearch-root .cr-lb.open{display:flex}
    .cnvresearch-root .cr-lb img{max-width:90vw;max-height:84vh;border-radius:10px;box-shadow:0 30px 80px rgba(0,0,0,.6)}
    .cnvresearch-root .cr-cls{position:absolute;top:24px;right:30px;color:#fff;font-size:34px;cursor:pointer;line-height:1;background:none;border:none}
    .cnvresearch-root .cr-cap{position:absolute;bottom:26px;left:0;right:0;text-align:center;color:#cfdae6;font-family:var(--mono);font-size:13px;letter-spacing:1px}

    .cnvresearch-root :focus-visible{outline:3px solid var(--teal);outline-offset:2px;border-radius:4px}
    @media(prefers-reduced-motion:reduce){.cnvresearch-root *{animation:none!important;transition:none!important}}
  </style>

  <script is:inline>
  /* ====================== DATOS ====================== */
  const FUNCIONES = [
    { icon:"🔬", color:"#e8f4f1", t:"Diseño y validación", d:"Diseño, validación y evolución continua del modelo ANI BIS-E con base en evidencia real de población latinoamericana." },
    { icon:"🧬", color:"#eef0f8", t:"Investigación clínica", d:"Investigación clínica y aplicada basada en data real del ecosistema CNV a nivel latinoamericano." },
    { icon:"📐", color:"#fdf6e3", t:"Estandarización", d:"Estandarización técnica, metodológica y de interpretación para toda la red de operadores CNV." },
    { icon:"💡", color:"#f4eef0", t:"Consultoría científica", d:"Consultoría especializada en medicina bioeléctrica y nutrición funcional para instituciones y aliados." },
    { icon:"📚", color:"#f0f4ee", t:"Producción editorial", d:"Divulgación científica, publicaciones y posicionamiento del modelo bajo el paradigma de salud bioeléctrica." }
  ];

  const LIBROS = [
    {
      img:"/images/portadas/portada_bioimpedancia.jpg",
      tag:"Bioimpedancia",
      titulo:"Bioimpedancia: el arte de medir lo invisible",
      desc:"Segunda edición. Referencia fundamental del campo: cada medición como puerta al conocimiento real del cuerpo humano. En lenguaje claro y científicamente riguroso.",
      amazon:"#amazon-1",
      gumroad:"#gumroad-1"
    },
    {
      img:"/images/portadas/portada_mas_alla_imc.jpg",
      tag:"Nutrición clínica",
      titulo:"Más allá del IMC: Lo que la electricidad dice y la medicina escucha",
      desc:"Datos de 1.729 adultos latinoamericanos. El 51,7% con normopeso tenía exceso real de grasa. El 24,1% con composición normal mostraba deterioro celular activo. Ninguno aparecía en el IMC.",
      amazon:"#amazon-2",
      gumroad:"#gumroad-2"
    },
    {
      img:"/images/portadas/portada_medicina_bioelectrica.jpg",
      tag:"Medicina bioeléctrica",
      titulo:"Medicina Bioeléctrica: El paradigma de la armonía humana",
      desc:"Presenta el sistema ANI BIS-E y su síntesis definitiva: el ICA-BIS. Para clínicos, investigadores y profesionales que quieran dejar de tratar síntomas y empezar a leer la célula.",
      amazon:"#amazon-3",
      gumroad:"#gumroad-3"
    }
  ];

  /* Producción científica relacionada con BIA (fuente: HV completa). Estado: 'publicado', 'en-proceso', 'tesis' */
  const ARTICULOS = [
    {
      tag:"Artículo científico",
      tagColor:"#147F76",
      titulo:"Valores de referencia para el ángulo de fase derivado de la impedancia bioeléctrica: un estudio transversal de 5049 individuos sanos de Colombia",
      meta:"Carrera-Gil F, Ramírez-Vélez R, Uribe Gil GJ &middot; <strong>European Journal of Clinical Nutrition</strong>",
      estado:"publicado",
      estadoLabel:"Publicado",
      link:"https://doi.org/10.1038/s41430-026-01744-z"
    },
    {
      tag:"Artículo científico",
      tagColor:"#147F76",
      titulo:"Multifrequency Bioimpedance Functional Cut-off Points for Noncommunicable Diseases Risk in Adults in Colombia and Mexico. A Multicenter Study",
      meta:"Uribe Gil GJ, Estudillo Muñoz EY &middot; <strong>Acta Scientific Nutritional Health</strong> &middot; 2025; 9(11):55-73",
      estado:"publicado",
      estadoLabel:"Publicado",
      link:"https://doi.org/10.31080/ASNH.2025.09.1582"
    },
    {
      tag:"Tesis doctoral",
      tagColor:"#16324F",
      titulo:"Caracterización bioeléctrica de adultos colombianos y mexicanos mediante bioimpedancia multifrecuencia",
      meta:"Gildardo de Jesús Uribe Gil &middot; <strong>UNINI México</strong> &middot; PhD en Salud Pública, Cum Laude &middot; n=1.729",
      estado:"tesis",
      estadoLabel:"Cum Laude",
      link:"#"
    },
    {
      tag:"Capítulo de libro",
      tagColor:"#16324F",
      titulo:"Índice de impedancia (IR) por BIA multifrecuencia: biomarcadores del estado nutricional de población adulta sana",
      meta:"Uribe Gil GJ, Ortiz Sepúlveda JD, Jaramillo Vasco ML &middot; <strong>Investigación en salud colectiva y ocupacional</strong>, Vol. 1 &middot; Editorial OCRONOS, 2024 &middot; Cap. 1.6",
      estado:"publicado",
      estadoLabel:"Publicado",
      link:"#"
    },
    {
      tag:"Capítulo de libro",
      tagColor:"#16324F",
      titulo:"Correlación del IMC y el porcentaje de grasa corporal obtenida por mfBIA en adultos colombianos",
      meta:"Uribe Gil GJ, Hincapié Vásquez D, Jiménez Rivera S &middot; <strong>Investigación en salud colectiva y ocupacional</strong>, Vol. 1 &middot; Editorial OCRONOS, 2024 &middot; Cap. 1.7",
      estado:"publicado",
      estadoLabel:"Publicado",
      link:"#"
    }
  ];

  const STATS = [
    { val:"BIS", lbl:"Bioimpedancia Espectroscópica como eje metodológico" },
    { val:"LATAM", lbl:"Alcance latinoamericano en expansión" },
    { val:"81", lbl:"Fenotipos clasificados en el modelo ANI BIS-E" },
    { val:"Cole-Cole", lbl:"Modelo biofísico de referencia internacional" }
  ];

  /* Artículos destacados del newsletter (agregar edición y URL de LinkedIn) */
  const NEWSLETTER = [
    { ed:"Edición 8", t:"IRC: Índice de Riesgo Celular", d:"El riesgo que el entorno impone a la célula: inflamación de bajo grado y daño de membrana.", url:"https://linkedin.com" },
    { ed:"Edición 34", t:"PABU: Proporción Áurea Bioeléctrica de Uribe", d:"El número que converge a phi en el individuo sano.", url:"https://linkedin.com" },
    { ed:"Edición reciente", t:"Mapa FyR BIS: IFC × IRC", d:"La bidimensionalidad que el ángulo de fase no puede ver.", url:"https://linkedin.com" }
  ];

  /* ====================== RENDER ====================== */
  const bookOk = new Set();
  function markBook(i){ bookOk.add(i); }

  const fg = document.getElementById('funcGrid');
  FUNCIONES.forEach(f => {
    fg.innerHTML += `<div class="func-card">
      <div class="func-icon" style="background:${f.color}">${f.icon}</div>
      <h3>${f.t}</h3><p>${f.d}</p>
    </div>`;
  });

  const bg = document.getElementById('booksGrid');
  LIBROS.forEach((l, i) => {
    bg.innerHTML += `<div class="book-card">
      <div class="book-cover-wrap" onclick="openLbBook(${i})">
        <div class="book-ph"><span class="book-ph-tag">${l.tag}</span><span class="book-ph-t">${l.titulo}</span></div>
        <img class="book-cover" src="${l.img}" alt="${l.titulo}" loading="lazy" onload="markBook(${i})" onerror="this.remove()"/>
      </div>
      <div class="book-body">
        <div class="book-tag">${l.tag}</div>
        <div class="book-title">${l.titulo}</div>
        <div class="book-desc">${l.desc}</div>
        <div class="book-author">Obra personal &middot; Gildardo de Jesús Uribe Gil</div>
        <div class="book-btns">
          <a href="${l.amazon}" target="_blank" rel="noopener" class="btn-sm filled">Amazon KDP</a>
          <a href="${l.gumroad}" target="_blank" rel="noopener" class="btn-sm">Gumroad</a>
        </div>
      </div>
    </div>`;
  });

  const al = document.getElementById('artList');
  ARTICULOS.forEach(a => {
    const cls = a.estado === 'publicado' ? 'status-pub' :
                a.estado === 'tesis' ? 'status-thesis' : 'status-wip';
    al.innerHTML += `<div class="art-card">
      <div>
        <div class="art-tag" style="color:${a.tagColor}">${a.tag}</div>
        <div class="art-title">${a.titulo}</div>
        <div class="art-meta">${a.meta}</div>
      </div>
      <div>
        <span class="art-status ${cls}">${a.estadoLabel}</span>
        ${a.link !== '#' ? `<br><a href="${a.link}" target="_blank" rel="noopener" style="font-size:12px;color:var(--teal);font-weight:600;display:inline-block;margin-top:10px">Ver &rarr;</a>` : ''}
      </div>
    </div>`;
  });

  const sg = document.getElementById('statsGrid');
  STATS.forEach(s => {
    sg.innerHTML += `<div class="stat"><div class="val">${s.val}</div><div class="lbl">${s.lbl}</div></div>`;
  });

  const ng = document.getElementById('nlGrid');
  NEWSLETTER.forEach(n => {
    ng.innerHTML += `<div class="nl-card">
      <div class="ed">${n.ed}</div>
      <h4>${n.t}</h4>
      <p>${n.d}</p>
      <a href="${n.url}" target="_blank" rel="noopener" class="leer">Leer en LinkedIn &rarr;</a>
    </div>`;
  });

  /* Tabs */
  document.querySelectorAll('.cnvresearch-root .tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.cnvresearch-root .tab-btn').forEach(b => b.classList.remove('on'));
      document.querySelectorAll('.cnvresearch-root .tab-panel').forEach(pn => pn.classList.remove('on'));
      btn.classList.add('on');
      document.getElementById('tab-' + btn.dataset.tab).classList.add('on');
    });
  });

  /* LIGHTBOX (modelo de imagenes igual que Nosotros) */
  function openLbBook(i){
    if (!bookOk.has(i)) return;
    const im = document.getElementById('crLbImg');
    im.src = LIBROS[i].img;
    im.alt = LIBROS[i].titulo;
    document.getElementById('crLbCap').textContent = LIBROS[i].titulo;
    document.getElementById('crLb').classList.add('open');
  }
  function closeLbBook(){ document.getElementById('crLb').classList.remove('open'); document.getElementById('crLbImg').src = ''; }
  document.getElementById('crLbClose').addEventListener('click', closeLbBook);
  document.getElementById('crLb').addEventListener('click', e => { if (e.target.id === 'crLb') closeLbBook(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLbBook(); });
  </script>

</BaseLayout>
