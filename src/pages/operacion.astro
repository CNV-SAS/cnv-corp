---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getI18n } from '../i18n';

// Componentes modulares
import OperationHero from '../components/pages/care/OperationHero.astro';
import OperationRole from '../components/pages/care/OperationRole.astro';
import ClinicalPhases from '../components/pages/care/ClinicalPhases.astro';
import AtlasPlatform from '../components/pages/care/AtlasPlatform.astro';
import ExclusivityAndProcess from '../components/pages/care/ExclusivityAndProcess.astro';

const lang = Astro.currentLocale || 'es';
const t = getI18n(lang);
const p = t.pages.operacion;
---

<BaseLayout
  title={`${p.title} — Connected Nutrition Ventures`}
  description={p.hero_body}
>
  <OperationHero />
  <OperationRole />
  <ClinicalPhases />
  <AtlasPlatform />
  <ExclusivityAndProcess />
</BaseLayout>