    document.getElementById('ccLb').classList.add('open');
  }
  function closeLbVit(){ document.getElementById('ccLb').classList.remove('open'); document.getElementById('ccLbImg').src = ''; }
  document.getElementById('ccLbClose').addEventListener('click', closeLbVit);
  document.getElementById('ccLb').addEventListener('click', e => { if (e.target.id === 'ccLb') closeLbVit(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLbVit(); });
