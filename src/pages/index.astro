---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getI18n } from '../i18n/index';

// Secciones
import Hero from '../components/sections/Hero.astro';
import Paradigm  from '../components/sections/Paradigm.astro';
import AnibiseModel from '../components/sections/AnibiseModel.astro';
import Ecosystem from '../components/sections/Ecosystem.astro';
import Audiences from '../components/sections/Audiences.astro';
import Benefits from '../components/sections/Benefits.astro';
import Partners from '../components/sections/Partners.astro';
import Process from '../components/sections/Process.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';

// Usamos el locale de Astro, y fallback a 'es'. 
// Mucho más dinámico que hardcodear 'es' en cada página.
const lang = Astro.currentLocale || 'es';
const t = getI18n(lang);
---

<BaseLayout
  title={t.seo.title}
  description={t.seo.description}
>
  <Hero />
  <Paradigm />
  <AnibiseModel />
  <Ecosystem />
  <Audiences />
  <Benefits />
  <Process />
  <Partners />
  <FinalCTA />
</BaseLayout>