---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getI18n } from '../i18n';

const tEs = getI18n('es');
const tEn = getI18n('en');
---

<BaseLayout title={`404 | Not Found - No encontrado`}>
  <section class="min-h-[80vh] flex items-center justify-center bg-white px-6">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-16 animate-on-scroll">
        <div class="text-xs font-700 tracking-[0.2em] uppercase text-cnv-generate mb-4">
          {tEs.not_found.title}
        </div>
        <h1 class="text-display-sm font-900 text-cnv-core mb-6">
          {tEs.not_found.subtitle}
        </h1>
        <p class="text-base text-cnv-core/60 mb-8 leading-relaxed max-w-md mx-auto">
          {tEs.not_found.body}
        </p>
        <a href={tEs.routes.home} class="btn-primary inline-flex">
          {tEs.not_found.back_home}
        </a>
      </div>

      <div class="w-24 h-px bg-cnv-core/10 mx-auto mb-16"></div>

      <div class="text-center animate-on-scroll [animation-delay:200ms]">
        <div class="text-xs font-700 tracking-[0.2em] uppercase text-cnv-bio mb-4">
          {tEn.not_found.title}
        </div>
        <h2 class="text-headline-sm font-800 text-cnv-core/80 mb-6">
          {tEn.not_found.subtitle}
        </h2>
        <p class="text-sm text-cnv-core/50 mb-8 leading-relaxed max-w-md mx-auto">
          {tEn.not_found.body}
        </p>
        <a href={tEn.routes.home} class="text-xs font-700 tracking-widest uppercase text-cnv-core/40 hover:text-cnv-core transition-colors">
          {tEn.not_found.back_home} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>